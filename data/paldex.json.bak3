 {
  "related_technology": null,
  "is_pal": true,
  "is_available_ingame": true,
  "pal_dev_name": "CatVampire",
  "pal_name": "夜幕魔蝠",
  "pal_description": "它会在黑暗中袭击猎物，用斗篷般的翅膀将其包裹起来。 \r\n至于翅膀内侧到底发生了什么，以及为什么会沾染上红色， \r\n这类问题还是不要深究为妙。",
  "partner_skill_title": "窃取生命",
