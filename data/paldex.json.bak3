 {
  "related_technology": null,
  "is_pal": true,
  "is_available_ingame": true,
  "pal_dev_name": "RobinHood",
  "pal_name": "羽箭射手",
  "pal_description": "这类帕鲁在森林里过着狩猎生活，特征习性等与人类十分接近。\r\n在远古时代，便走上了与人类不同的进化之路。\r\n但也许它们就是能解答「帕鲁为何物」这个问题的关键。",
